# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# real values before running `docker compose up`. docker compose reads `.env`
# automatically. These are consulted ONLY on first run, when no admin user
# exists yet in the database — after that they are ignored.

# Admin username. 2-64 chars: letters, digits, or any of . _ - @ + (emails OK).
EXOTICK_ADMIN_USERNAME=admin

# Admin password. At least 8 characters. There is NO default — compose will
# refuse to start until this is set. Pick something strong and unique, then
# change it from Settings > Change my password after your first sign-in.
EXOTICK_ADMIN_PASSWORD=
