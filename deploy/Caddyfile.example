# Caddyfile for exotick — copy to /etc/caddy/Caddyfile on the VPS, swap the
# domain, then `sudo systemctl reload caddy`. Caddy fetches Let's Encrypt
# certs automatically the first time the domain is served over :443.

exotick.example.com {
	# Uploads and API alike are proxied — exotick serves both from one port.
	reverse_proxy 127.0.0.1:3001

	# Encourage HTTPS-only for the year. Only enable this after you've
	# confirmed the site works end-to-end without it, otherwise you'll bake
	# yourself into HTTPS while debugging cert issues.
	# header Strict-Transport-Security "max-age=31536000; includeSubDomains"
}
